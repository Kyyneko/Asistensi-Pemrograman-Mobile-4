# --- Gradle ---
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# --- Android Studio / IntelliJ IDEA ---
.idea/
*.iml
*.iws
*.ipr

# --- Local Configuration ---
local.properties
*.cfg
*.log

# --- Build Output ---
*.apk
*.aab
*.ap_
*.dex

# --- Proguard ---
proguard/

# --- Android Generated Files ---
gen/
out/
bin/

# --- Signing ---
*.jks
*.keystore

# --- Captures ---
captures/

# --- External Native Build ---
.externalNativeBuild/
.cxx/

# --- Google Services (opsional, jika mengandung API key) ---
# google-services.json

# --- OS Generated Files ---
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Misc ---
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
*.tmp
*.swp
*.swo
*~
