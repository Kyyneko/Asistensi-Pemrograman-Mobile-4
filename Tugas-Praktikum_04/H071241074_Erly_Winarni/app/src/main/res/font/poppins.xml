<?xml version="1.0" encoding="utf-8"?>
<!--
    CATATAN PENTING:
    File font .ttf harus diunduh manual dari Google Fonts:
    https://fonts.google.com/specimen/Poppins

    Download lalu taruh file berikut di folder res/font/ :
      - poppins_regular.ttf
      - poppins_semibold.ttf  (SemiBold 600)
      - poppins_bold.ttf      (Bold 700)

    Atau gunakan cara otomatis lewat Android Studio:
    Klik kanan res/font → New → Font Resource File → pilih Poppins dari Google Fonts
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <font
        android:font="@font/poppins_regular"
        android:fontStyle="normal"
        android:fontWeight="400"
        app:font="@font/poppins_regular"
        app:fontStyle="normal"
        app:fontWeight="400" />

    <font
        android:font="@font/poppins_semibold"
        android:fontStyle="normal"
        android:fontWeight="600"
        app:font="@font/poppins_semibold"
        app:fontStyle="normal"
        app:fontWeight="600" />

    <font
        android:font="@font/poppins_bold"
        android:fontStyle="normal"
        android:fontWeight="700"
        app:font="@font/poppins_bold"
        app:fontStyle="normal"
        app:fontWeight="700" />

</font-family>
