<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <RelativeLayout
        android:id="@+id/rl_quiz_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:layout_marginTop="24dp"
        android:background="@color/bg_card"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/iv_close_quiz"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/icon_close" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_quiz_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category: Loading ...."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"/>

            <TextView
                android:id="@+id/tv_question_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Question 1 / 5"
                android:textColor="#0263A1"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_current_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="⭐ 0"
            android:textColor="#FFA000"
            android:textSize="16sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/pb_timer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/rl_quiz_header"
        android:progress="100"
        app:indicatorColor="#C62828"
        app:trackColor="#E2E8F0"
        app:trackThickness="6dp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_question_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/pb_timer"
        android:layout_margin="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/bg_card">

        <TextView
            android:id="@+id/tv_question_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="150dp"
            android:padding="24dp"
            android:gravity="center"
            android:text="Loading questions from server ... Get Ready!"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:lineSpacingExtra="6dp" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/cv_question_container"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_option_a"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="12dp"
            android:text="A. Loading ...."
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textAllCaps="false"
            app:strokeColor="#CFD8DC"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_option_b"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="12dp"
            android:text="B. Loading ...."
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textAllCaps="false"
            app:strokeColor="#CFD8DC"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_option_c"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="12dp"
            android:text="C. Loading ...."
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textAllCaps="false"
            app:strokeColor="#CFD8DC"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_option_d"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="12dp"
            android:text="D. Loading ...."
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textAllCaps="false"
            app:strokeColor="#CFD8DC"
            app:cornerRadius="16dp" />
    </LinearLayout>

</RelativeLayout>